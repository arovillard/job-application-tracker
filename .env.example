# Copy this file to .env.local or run `npm run setup`.

# SQLite database used by the Next.js app and the job-tracker skill.
JOBTRACKER_DB_PATH="./data/jobtracker.sqlite"

# Destination for generated resumes, fit analyses, outreach drafts, and posting PDFs.
JOBTRACKER_APPLICATIONS_DIR="./applications"

# Optional source material for AI-assisted application work.
JOBTRACKER_BASE_RESUME_PATH=""
JOBTRACKER_LINKEDIN_URL=""

# Optional note for agents. Configure provider credentials outside this repo.
JOBTRACKER_AI_PROVIDER=""
