# Copy this file to .env.local or run `npm run setup`.

# SQLite database shared by the Next.js app, job-tracker skill, and local agent worker.
JOBTRACKER_DB_PATH="./data/jobtracker.sqlite"

# Workflow write boundary for generated resumes, fit analyses, outreach drafts, and posting PDFs.
JOBTRACKER_APPLICATIONS_DIR="./applications"

# Optional source material for AI-assisted application work. Keep resume files private.
JOBTRACKER_BASE_RESUME_PATH=""
JOBTRACKER_LINKEDIN_URL=""

# Provider executable paths and default models belong only in the ignored
# jobtracker.agent.local.json file; copy jobtracker.agent.example.json as a template.
# Authenticate with the host provider CLI. Do not add API keys or secrets here.

# Optional note for agents. Configure provider credentials outside this repo.
JOBTRACKER_AI_PROVIDER=""
