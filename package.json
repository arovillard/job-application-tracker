{
  "name": "opportunity-tracker",
  "version": "0.1.7",
  "description": "Local-first opportunity tracker for jobs and connections with packaged Codex and Claude workflows.",
  "license": "PolyForm-Noncommercial-1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "setup": "node scripts/setup-user.mjs",
    "skills:install": "node scripts/install-skills.mjs",
    "skills:install:codex": "node scripts/install-skills.mjs --codex",
    "skills:install:claude": "node scripts/install-skills.mjs --claude",
    "artifacts:backfill": "node scripts/backfill-application-artifacts.mjs",
    "verify": "npm run lint && npm run typecheck && npm run test"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "nanoid": "^5.1.16",
    "next": "^16.2.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "react-pdf": "^10.4.1",
    "zod": "^4.4.3"
  },
  "overrides": {
    "postcss": "^8.5.16"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.10",
    "jsdom": "^29.1.1",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  }
}
